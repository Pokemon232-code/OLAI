[
  {
    "id": "finance.zerodha",
    "name": "Zerodha Kite",
    "category": "Tools",
    "icon": "📈",
    "description": "Monitor stocks and manage orders on Zerodha Kite (No-API mode).",
    "handlerType": "browser",
    "url": "https://kite.zerodha.com",
    "actions": [
      { "value": "check_portfolio", "label": "Check Portfolio", "fields": ["account_id"], "description": "View current holdings and P&L" },
      { "value": "get_quote", "label": "Get Stock Quote", "fields": ["symbol"], "description": "Fetch real-time price for a specific symbol" },
      { "value": "place_order", "label": "Place Order", "fields": ["symbol", "quantity", "order_type"], "description": "Place a buy/sell order via browser automation" }
    ],
    "fields": [
      { "key": "account_id", "label": "User ID", "type": "text", "placeholder": "Your Zerodha ID" },
      { "key": "symbol", "label": "Stock Symbol", "type": "text", "placeholder": "e.g. RELIANCE" },
      { "key": "quantity", "label": "Quantity", "type": "number", "default": 1 },
      { "key": "order_type", "label": "Order Type", "type": "select", "default": "BUY", "options": [
        { "label": "BUY", "value": "BUY" },
        { "label": "SELL", "value": "SELL" }
      ]}
    ]
  },
